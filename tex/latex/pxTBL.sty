%% Package configuration (pxTAB key family).
%%   Options are only processed at load time via \usepackage[options]{pxTAB}.
%%   \pxTABsetup sets keys for current scope only (e.g. for compatibility); do not call \ProcessKeysOptions in document.
\NewDocumentCommand{\pxTABsetup}{m}{
	\keys_set:nn { pxTBL } { #1 }
	\ProcessKeysOptions{ pxTBL }
}
%% \pxTBLtop[maxwidth]{numcols}[gap]{headers}[rows prefix]{rows}
\NewDocumentCommand{\pxTBLtop}{s O{\linewidth} m O{\quad} m O{p} +m}
{
	\IfBooleanTF{#1}
	{\_pxtable_tophead:nnnnnnn {#5}{#7}{#3}{#2}{#4}{#6}{#1}}
	{\_pxtable_tophead:nnnnnnn {#5}{#7}{#3}{#2}{#4}{#6}{}}
}
\NewDocumentCommand{\pxTBL}{s O{\linewidth} m O{\quad} m O{p} +m}
{
	\IfBooleanTF{#1}
	{\_pxtable_list:nnnnnnn {#5}{#7}{#3}{#2}{#4}{#6}{#1}}
	{\_pxtable_list:nnnnnnn {#5}{#7}{#3}{#2}{#4}{#6}{}}
}
\NewDocumentCommand{\pxTBLlong}{s O{\linewidth} m O{\quad} m O{p} +m}
{
	\IfBooleanTF{#1}
	{\_pxtable_toplong:nnnnnnn {#5}{#7}{#3}{#2}{#4}{#6}{#1}}
	{\_pxtable_toplong:nnnnnnn {#5}{#7}{#3}{#2}{#4}{#6}{}}
}