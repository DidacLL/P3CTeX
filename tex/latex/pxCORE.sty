%%  Version: v0.2 (02/2026)
%%  Description:
%%    Core aggregation package for P3CTeX.
%%    - Centralises third-party package loading and layout utilities
%%      that are shared across P3CTeX documents.
%%    - Owns the `pxCORE` key family, which controls activation and
%%      configuration of standalone libraries (pxUML, pxPRP, ...).
%%    - Does not define document-class–specific user commands; those
%%      belong in `P3CTeX.cls` or in standalone libraries.
%%
%%  Architectural role:
%%    - pxCORE is the single integration point for standalone libraries.
%%      Document classes (such as P3CTeX.cls) load `pxCORE` and pass
%%      options down; they never talk to pxUML/pxPRP directly.
%%    - Standalone libraries (pxUML, pxPRP, pxSRC) only
%%      expose their own public LaTeX2e API and expl3 internals; they
%%      have no knowledge of document classes.
%%    - All expl3 implementation for pxCORE lives in `pxCORE.code.tex`.
%%
%%  This file may be distributed and/or modified:
%%
%%   1. under the LaTeX Project Public License and/or
%%   2. under the GNU Public License.
%%
%%   See the file doc/LICENSE for more details.
%% =======================================================
\RequirePackage[utf8]{inputenc}
\RequirePackage{expl3}
\RequirePackage{color,l3keys2e,xparse}
\ProvidesExplPackage{pxCORE}{2026/02/24}{v0.2}
{
	P3CTeX CORE Module
}
