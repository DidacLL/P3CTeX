\RequirePackage{expl3}
\RequirePackage{xparse,l3keys2e}
\RequirePackage{listings}
\RequirePackage{listingsutf8}
\RequirePackage[table]{xcolor}
\RequirePackage{tcolorbox}
\tcbuselibrary{listings,listingsutf8,breakable,xparse,skins}
\ProvidesExplPackage{pxLST}{2026/03/04}{v0.1}{P3CTeX professional code listings}
\file_input:n {pxLST.code.tex}
%%% P3CTeX branded presets (registered before option processing
%%% so that \usepackage[preset=p3c-code]{pxLST} works).
\@ifclassloaded{P3CTeX}
{
  \pxLST_save_preset:nn { p3c-code }
    { style=dark, language=pxJava, numbers=left, breakable=true }
  \pxLST_save_preset:nn { p3c-alg }
    { style=framed, language=algoritme, numbers=left, breakable=false }
  \pxLST_save_preset:nn { p3c-plain }
    { style=plain, language=pxJava, numbers=none, breakable=false }
}{}
\ProcessKeysOptions{ pxLST }
