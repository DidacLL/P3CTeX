%% Palette selection model (alias-based, no expl3 tl state):
%% - Stable alias color names `px<role>` are used everywhere in listings/tcolorbox.
%% - Role macros map directly to these aliases, e.g. \color{pxfg} -> \color{pxfg}.
%% - Palette macros only `\colorlet` the aliases to concrete dark/pastel/light colors.
\colorlet{pxbg}{dark-bg}
\colorlet{pxfg}{dark-fg}
\colorlet{pxkeyword}{dark-keyword}
\colorlet{pxstring}{dark-string}
\colorlet{pxtag}{dark-tag}
\colorlet{pxcomment}{dark-comment}
\colorlet{pxnumber}{dark-number}
\colorlet{pxtype}{dark-type}
\colorlet{pxfunction}{dark-function}
\colorlet{pxoperator}{dark-operator}
\def\pxLSTpalettedark{%
  \colorlet{pxbg}{dark-bg}%
  \colorlet{pxfg}{dark-fg}%
  \colorlet{pxkeyword}{dark-keyword}%
  \colorlet{pxstring}{dark-string}%
  \colorlet{pxtag}{dark-tag}%
  \colorlet{pxcomment}{dark-comment}%
  \colorlet{pxnumber}{dark-number}%
  \colorlet{pxtype}{dark-type}%
  \colorlet{pxfunction}{dark-function}%
  \colorlet{pxoperator}{dark-operator}%
}
\def\pxLSTpalettepastel{%
  \colorlet{pxbg}{pastel-bg}%
  \colorlet{pxfg}{pastel-fg}%
  \colorlet{pxkeyword}{pastel-keyword}%
  \colorlet{pxstring}{pastel-string}%
  \colorlet{pxtag}{pastel-tag}%
  \colorlet{pxcomment}{pastel-comment}%
  \colorlet{pxnumber}{pastel-number}%
  \colorlet{pxtype}{pastel-type}%
  \colorlet{pxfunction}{pastel-function}%
  \colorlet{pxoperator}{pastel-operator}%
}
\def\pxLSTpalettelight{%
  \colorlet{pxbg}{light-bg}%
  \colorlet{pxfg}{light-fg}%
  \colorlet{pxkeyword}{light-keyword}%
  \colorlet{pxstring}{light-string}%
  \colorlet{pxtag}{light-tag}%
  \colorlet{pxcomment}{light-comment}%
  \colorlet{pxnumber}{light-number}%
  \colorlet{pxtype}{light-type}%
  \colorlet{pxfunction}{light-function}%
  \colorlet{pxoperator}{light-operator}%
}
\makeatletter
\def\pxLSTpaletteSelect#1{%
  \edef\pxLST@tmp{#1}%
  \ifx\pxLST@tmp\@empty
    \pxLSTpalettedark
  \else
    \@ifundefined{pxLSTpalette#1}{%
      \pxLSTpalettedark
    }{%
      \csname pxLSTpalette#1\endcsname
    }%
  \fi
}
\makeatother
