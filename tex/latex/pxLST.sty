%% =================================
%% ===== FILE INPUT FUNCTION ========
%% =================================
\cs_new_protected:Npn \pxLST_input_file:nn #1 #2 {
	\tcbinputlisting{
		listing~options={language=#1},
		colback=pxbg!90!,
		colframe=pxbg!60!,
		coltext=pxfg,
		listing~file=#2,
		listing~only,
		arc=.25em, outer~arc=.25em,
		drop~lifted~shadow,
		toptitle=-.1em,
		title=\small\hspace*{\fill}\textbf{\ttfamily #2}
	}
}
%% =================================
%% ===== INLINE CODE RENDER ==========
%% =================================
%% Small tcolorbox with lstinline for single-snippet inline code.
\cs_new_protected:Npn \__pxlst_code_render_inline:n #1 {
	\tcbox[
	nobeforeafter,
	size=minimal,
	colback=pxbg!90!,
	colframe=pxbg!60!,
	coltext=pxfg,
	boxrule=0.4pt,
	arc=0.5mm,
	left=1.5pt,
	right=1.5pt,
	top=0.5pt,
	bottom=0.5pt,
	]
	{ \lstinline{#1} }
}


