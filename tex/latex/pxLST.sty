%% --- pxJava: Java with extended keyword sets and annotation delimiter ---
\lstdefinelanguage{pxJava}{
	language         = Java,
	emph             = {this,super},
	deletekeywords     = {void,new,null,true,false,for,if,else,elseif,while,do,switch,case,foreach,break},
	morekeywords     = [5]{void,new,null,true,false,for,if,else,elseif,while,do,switch,case,foreach,break},
	deletekeywords     = {main,println,System,out,in,err,format,add,get,size,remove,put,contains,keySet,values,equals},
	deletekeywords     = {String,Integer,int,char,long,short,byte,float,Double,Boolean,boolean,ArrayList,List,Map,Set},
	morekeywords     = [2]{String,Integer,int,char,long,short,byte,float,Double,Boolean,boolean,ArrayList,List,Map,Set},
	morekeywords     = [2]{main,println,System,out,in,err,format,add,get,size,remove,put,contains,keySet,values,equals},
	moredelim        = [s][stringstyle]{<<}{>>},
	moredelim 		 =**[s][stringstyle]{[}{]},
	moredelim        = [s][commentstyle]{/*}{*/},
	moredelim        = [l][\itshape\pxDEFlsttag]{@},
}
%% --- pxProlog: Prolog with operator literate coloring ---
\lstdefinelanguage{pxProlog}{
	language         = Prolog,
	keywordstyle     = \pxDEFlstkeyword\bfseries,
	keywordstyle     = [3]\pxDEFlstfunction\bfseries,
	morekeywords     = [3]{atom_length,append,member,length,findall,nl,write},
	literate         =
	{(}{{\pxDEFlstfunction(}}1
	{)}{{\pxDEFlstfg)}}1
	{.}{{\pxDEFlstkeyword\bfseries.\pxDEFlstfg}}1
	{,}{{\pxDEFlstoperator,\pxDEFlstfg}}1
	{:-}{{\pxDEFlstkeyword\bfseries{}:-\pxDEFlstfg}}2
	{<}{{\pxDEFlstoperator<\pxDEFlstfg}}1
	{>}{{\pxDEFlstoperator>\pxDEFlstfg}}1
	{á}{{\'{a}}}1 {é}{{\'{e}}}1 {í}{{\'{i}}}1 {ó}{{\'{o}}}1 {ú}{{\'{u}}}1
	{Á}{{\'{A}}}1 {É}{{\'{E}}}1 {Í}{{\'{I}}}1 {Ó}{{\'{O}}}1 {Ú}{{\'{U}}}1
	{à}{{\`{a}}}1 {è}{{\`{e}}}1 {ì}{{\`{i}}}1 {ò}{{\`{o}}}1 {ù}{{\`{u}}}1
	{À}{{\`{A}}}1 {È}{{\`{E}}}1 {Ì}{{\`{I}}}1 {Ò}{{\`{O}}}1 {Ù}{{\`{U}}}1
	{ç}{{\c{c}}}1 {Ç}{{\c{C}}}1 {ñ}{{\~n}}1 {Ñ}{{\~N}}1,
}
