%% Palette selection model (alias-based, no expl3 tl state):
%% - Stable alias color names `pxlst-<role>` are used everywhere in listings/tcolorbox.
%% - Role macros map directly to these aliases, e.g. \pxDEFlstfg -> \color{pxlst-fg}.
%% - Palette macros only `\colorlet` the aliases to concrete dark/pastel/light colors.
\colorlet{pxlst-bg}{dark-bg}
\colorlet{pxlst-fg}{dark-fg}
\colorlet{pxlst-keyword}{dark-keyword}
\colorlet{pxlst-string}{dark-string}
\colorlet{pxlst-tag}{dark-tag}
\colorlet{pxlst-comment}{dark-comment}
\colorlet{pxlst-number}{dark-number}
\colorlet{pxlst-type}{dark-type}
\colorlet{pxlst-function}{dark-function}
\colorlet{pxlst-operator}{dark-operator}
\def\pxDEFlstbg{\color{pxlst-bg}}
\def\pxDEFlstbgv{pxlst-bg}
\def\pxDEFlstfg{\color{pxlst-fg}}
\def\pxDEFlstfgv{pxlst-fg}
\def\pxDEFlstkeyword{\color{pxlst-keyword}}
\def\pxDEFlststring{\color{pxlst-string}}
\def\pxDEFlsttag{\color{pxlst-tag}}
\def\pxDEFlstcomment{\color{pxlst-comment}}
\def\pxDEFlstnumber{\color{pxlst-number}}
\def\pxDEFlsttype{\color{pxlst-type}}
\def\pxDEFlstfunction{\color{pxlst-function}}
\def\pxDEFlstoperator{\color{pxlst-operator}}
\def\pxDEFlstnumberv{pxlst-number}
\def\pxDEFlstnumbervFifty{pxlst-number!50!}
\def\pxDEFlstfgvFifty{pxlst-fg!50!}
\def\pxDEFlstfgvSeventyFive{pxlst-fg!75!}
\def\pxLSTpalettedark{%
  \colorlet{pxlst-bg}{dark-bg}%
  \colorlet{pxlst-fg}{dark-fg}%
  \colorlet{pxlst-keyword}{dark-keyword}%
  \colorlet{pxlst-string}{dark-string}%
  \colorlet{pxlst-tag}{dark-tag}%
  \colorlet{pxlst-comment}{dark-comment}%
  \colorlet{pxlst-number}{dark-number}%
  \colorlet{pxlst-type}{dark-type}%
  \colorlet{pxlst-function}{dark-function}%
  \colorlet{pxlst-operator}{dark-operator}%
}
\def\pxLSTpalettepastel{%
  \colorlet{pxlst-bg}{pastel-bg}%
  \colorlet{pxlst-fg}{pastel-fg}%
  \colorlet{pxlst-keyword}{pastel-keyword}%
  \colorlet{pxlst-string}{pastel-string}%
  \colorlet{pxlst-tag}{pastel-tag}%
  \colorlet{pxlst-comment}{pastel-comment}%
  \colorlet{pxlst-number}{pastel-number}%
  \colorlet{pxlst-type}{pastel-type}%
  \colorlet{pxlst-function}{pastel-function}%
  \colorlet{pxlst-operator}{pastel-operator}%
}
\def\pxLSTpalettelight{%
  \colorlet{pxlst-bg}{light-bg}%
  \colorlet{pxlst-fg}{light-fg}%
  \colorlet{pxlst-keyword}{light-keyword}%
  \colorlet{pxlst-string}{light-string}%
  \colorlet{pxlst-tag}{light-tag}%
  \colorlet{pxlst-comment}{light-comment}%
  \colorlet{pxlst-number}{light-number}%
  \colorlet{pxlst-type}{light-type}%
  \colorlet{pxlst-function}{light-function}%
  \colorlet{pxlst-operator}{light-operator}%
}
\makeatletter
\def\pxLSTpaletteSelect#1{%
  \edef\pxLST@tmp{#1}%
  \ifx\pxLST@tmp\@empty
    \pxLSTpalettedark
  \else
    \@ifundefined{pxLSTpalette#1}{%
      \pxLSTpalettedark
    }{%
      \csname pxLSTpalette#1\endcsname
    }%
  \fi
}
\makeatother
