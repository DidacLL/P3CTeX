%% =================================
%% ===== KEY DEFINITIONS (pxLST) ===
%% =================================
\keys_define:nn { pxLST }
{
	palette      .tl_set:N   = \l_pxlst_style_tl,
	palette      .initial:n  = {dark},
	colback    .tl_set:N   = \l_pxlst_colback_tl,
	colback    .initial:n  = {dark-bg!90!},
	colframe    .tl_set:N   = \l_pxlst_colframe_tl,
	colframe    .initial:n  = {dark-bg!60!},
	coltext    .tl_set:N   = \l_pxlst_coltext_tl,
	coltext    .initial:n  = {dark-fg},
	DARK			.meta:n	=	{
		colback={ dark-bg!90! },
		colframe={ dark-bg!60! },
		coltext={ dark-fg },
	},
	FRAMED		.meta:n	=	{
		colback={ dark-bg!90! },
		colframe={ dark-comment!60!},
		coltext={ dark-fg },
	},
	LIGHT			.meta:n	=	{
		colback={ white},
		colframe={ gray!25! },
		coltext={ black },
	},
	PLAIN			.meta:n	=	{
		colback={ white},
		colframe={ gray!15! },
		coltext={ black },
	},
	language   .tl_set:N   = \l_pxlst_language_tl,
	language   .initial:n  = pxJava,
	numbers    .tl_set:N   = \l_pxlst_numbers_tl,
	numbers    .initial:n  =  left,
	caption    .tl_set:N   = \l_pxlst_caption_tl,
	caption    .initial:n  = {},
	label      .tl_set:N   = \l_pxlst_label_tl,
	label      .initial:n  = {},
	float      .tl_set:N   = \l_pxlst_float_tl,
	float      .initial:n  = {},
	breakable  .bool_set:N = \l_pxlst_breakable_bool,
	breakable  .initial:n  = true,
	fontsize   .tl_set:N   = \l_pxlst_fontsize_tl,
	fontsize   .initial:n  = \footnotesize,
	linespread .tl_set:N   = \l_pxlst_linespread_tl,
	linespread .initial:n  = 1.2,
	tabsize    .int_set:N  = \l_pxlst_tabsize_int,
	tabsize    .initial:n  = 4,
	unknown    .code:n     = {},
}
