% =================================
% ===== BASE STYLE ===============
% =================================
\lstdefinestyle{pxlst}{
	inputencoding    = utf8,
	extendedchars    = true,
	basicstyle       = \footnotesize\linespread{1.2}\ttfamily\pxDEFlstfg,
	identifierstyle  = \pxDEFlstfg,
	commentstyle     = \itshape\pxDEFlstcomment,
	stringstyle      = \pxDEFlststring,
	keywordstyle     = \bfseries\pxDEFlstkeyword,
	keywordstyle     = [2]\bfseries\pxDEFlstfunction,
	keywordstyle     = [3]\pxDEFlsttype,
	keywordstyle     = [4]\itshape\pxDEFlsttag,
	emphstyle        = \underbar\pxDEFlstoperator,
	showstringspaces = false,
	showspaces       = false,
	showtabs         = false,
	showlines        = false,
	breaklines       = true,
	breakatwhitespace= true,
	breakindent      = 4em,
	breakautoindent  = false,
	keepspaces       = true,
	tabsize          = 4,
	escapeinside     = {\%*}{*)},
	captionpos       = b,
	numbers          = left,
	numbersep		 = .8em,
	numberstyle      = \tiny\ttfamily\color{\pxlst_color_v:nn{number}{50!}}\hspace{-1em},
	prebreak  = \parbox[t][.1em][c]{\fill}{
		\vspace{.5em}\raggedleft
		\scalebox{-.8}[1.2]{
			\pxlst_color_v:nn{fg}{50!}$\hookrightarrow$
			}
	},
	postbreak = \parbox[b][1em][c]{2em}{\scalebox{.8}{%
			\pxlst_color_v:nn{fg}{50!}$\hookrightarrow$\hspace{2em}}},
	literate =
	{ГЎ}{{\'{a}}}1 {Г©}{{\'{e}}}1 {Гӯ}{{\'{i}}}1 {Гі}{{\'{o}}}1 {Гә}{{\'{u}}}1
	{ГҒ}{{\'{A}}}1 {Гү}{{\'{E}}}1 {ГҚ}{{\'{I}}}1 {Г“}{{\'{O}}}1 {Гҡ}{{\'{U}}}1
	{Г }{{\`{a}}}1 {ГЁ}{{\`{e}}}1 {Г¬}{{\`{i}}}1 {ГІ}{{\`{o}}}1 {Г№}{{\`{u}}}1
	{ГҖ}{{\`{A}}}1 {ГҲ}{{\`{E}}}1 {ГҢ}{{\`{I}}}1 {Г’}{{\`{O}}}1 {Гҷ}{{\`{U}}}1
	{ГӨ}{{\"a}}1  {Г«}{{\"e}}1  {ГҜ}{{\"i}}1  {Г¶}{{\"o}}1  {Гј}{{\"u}}1
	{Г„}{{\"A}}1  {ГӢ}{{\"E}}1  {ГҸ}{{\"I}}1  {Г–}{{\"O}}1  {Гң}{{\"U}}1
	{Гў}{{\^a}}1  {ГӘ}{{\^e}}1  {Г®}{{\^i}}1  {Гҙ}{{\^o}}1  {Г»}{{\^u}}1
	{ГӮ}{{\^A}}1  {ГҠ}{{\^E}}1  {ГҺ}{{\^I}}1  {Г”}{{\^O}}1  {Гӣ}{{\^U}}1
	{Г§}{{\c{c}}}1 {ГҮ}{{\c{C}}}1 {Гұ}{{\~n}}1 {Г‘}{{\~N}}1
	{Вҝ}{{?`}}1   {ВЎ}{{!`}}1,

}





%% =================================
%% ===== STYLE DEFINITIONS ==========
%% =================================
\lstdefinestyle{block}{
%	basicstyle=pxlst,
	style=pxlst,
	frame            = none,
}

\lstdefinestyle{framed}{
	frame= bottomtop,
	style=pxlst,
	framesep		= .5em,
%	framexleftmargin= 4em,
%	xleftmargin		= 2em,
	rulecolor 		= \color{\pxlst_color_v:nn{number}{50!}},
}

\lstdefinestyle{plain}{
	style=pxlst,
	frame= none,
}
%% =================================
%% ===== LANGUAGE DEFINITIONS =======
%% =================================
%% --- pxJava: Java with extended keyword sets and annotation delimiter ---
\lstdefinelanguage{pxJava}{
	language         = Java,
	emph             = {this,super},
	morekeywords     = [1]{String,Integer,int,char,long,short,byte,float,Double,
		Boolean,boolean,ArrayList,List,Map,Set,
		return,void,new,null,true,false},
	morekeywords     = [2]{main,println,System,out,in,err,format,
		add,get,size,remove,put,contains,keySet,values,equals},
	moredelim        = [s][stringstyle]{<<}{>>},
	moredelim        = [s][commentstyle]{/*}{*/},
	moredelim        = [l][\itshape\pxDEFlsttag]{@},
}
%% --- pxProlog: Prolog with operator literate coloring ---
\lstdefinelanguage{pxProlog}{
	language         = Prolog,
	keywordstyle     = \pxDEFlstkeyword\bfseries,
	keywordstyle     = [3]\pxDEFlstfunction\bfseries,
	morekeywords     = [3]{atom_length,append,member,length,findall,nl,write},
	literate         =
	{(}{{\pxDEFlstfunction(}}1
	{)}{{\pxDEFlstfg)}}1
	{.}{{\pxDEFlstkeyword\bfseries.\pxDEFlstfg}}1
	{,}{{\pxDEFlstoperator,\pxDEFlstfg}}1
	{:-}{{\pxDEFlstkeyword\bfseries{}:-\pxDEFlstfg}}2
	{<}{{\pxDEFlstoperator<\pxDEFlstfg}}1
	{>}{{\pxDEFlstoperator>\pxDEFlstfg}}1
	{ГЎ}{{\'{a}}}1 {Г©}{{\'{e}}}1 {Гӯ}{{\'{i}}}1 {Гі}{{\'{o}}}1 {Гә}{{\'{u}}}1
	{ГҒ}{{\'{A}}}1 {Гү}{{\'{E}}}1 {ГҚ}{{\'{I}}}1 {Г“}{{\'{O}}}1 {Гҡ}{{\'{U}}}1
	{Г }{{\`{a}}}1 {ГЁ}{{\`{e}}}1 {Г¬}{{\`{i}}}1 {ГІ}{{\`{o}}}1 {Г№}{{\`{u}}}1
	{ГҖ}{{\`{A}}}1 {ГҲ}{{\`{E}}}1 {ГҢ}{{\`{I}}}1 {Г’}{{\`{O}}}1 {Гҷ}{{\`{U}}}1
	{Г§}{{\c{c}}}1 {ГҮ}{{\c{C}}}1 {Гұ}{{\~n}}1 {Г‘}{{\~N}}1,
}
%% --- pxOWL: Manchester OWL Syntax ---
\lstdefinelanguage{pxOWL}{
	morekeywords     = {AnnotationProperty,Annotations,Asymmetric,
		Characteristics,Class,
		Datatype,DataProperty,DatatypeProperty,
		DifferentFrom,DifferentIndividuals,DisjointClasses,
		DisjointProperties,DisjointUnionOf,DisjointWith,Domain,
		EquivalentClasses,EquivalentProperties,EquivalentTo,
		Facts,Functional,
		HasKey,
		Import,Individual,InverseFunctional,InverseOf,Irreflexive,
		ObjectProperty,
		Ontology,
		Prefix,
		Range,Reflexive,
		SameAs,SameIndividual,Self,SubClassOf,SubPropertyChain,
		SubPropertyOf,Symmetric,
		Transitive,Types,
		and,exactly,inverse,langPattern,length,
		max,maxLength,min,minLength,
		not,only,or,pattern,some,that,value},
	morekeywords     = [3]{rdf,owl},
	keywordstyle     = \pxDEFlstkeyword\bfseries,
	keywordstyle     = [3]\pxDEFlstfunction\bfseries,
	morecomment      = [l]{\#},
	morestring       = [b]",
	literate         =
	{.}{{\pxDEFlstoperator\bfseries.\pxDEFlstfg}}1
	{:}{{\pxDEFlstoperator:\pxDEFlstfg}}1,
}
%% --- pxTAD: Abstract Data Type specification language ---
\lstdefinelanguage{pxTAD}{
	morekeywords     = {create,return,if,else,true,false,null},
	morekeywords     = [2]{TAD,@pre,@post,Invariant,Boolean,Integer,String,Date,List},
	morekeywords     = [3]{},
	keywordstyle     = \pxDEFlstkeyword\bfseries,
	keywordstyle     = [2]\pxDEFlstfunction\bfseries,
	keywordstyle     = [3]\pxDEFlsttype\bfseries,
	morecomment      = [l]{//},
	morecomment      = [s]{/*}{*/},
	morestring       = [b]",
	literate         =
	{.}{{\pxDEFlstkeyword\bfseries.\pxDEFlstfg}}1
	{,}{{\pxDEFlstoperator,\pxDEFlstfg}}1
	{:}{{\pxDEFlstkeyword\bfseries{}:\pxDEFlstfg}}1
	{<}{{\pxDEFlstoperator<\pxDEFlsttype}}1
	{>}{{\pxDEFlstoperator>\pxDEFlstfg}}1
	{ГЎ}{{\'{a}}}1 {Г©}{{\'{e}}}1 {Гӯ}{{\'{i}}}1 {Гі}{{\'{o}}}1 {Гә}{{\'{u}}}1
	{Г }{{\`{a}}}1 {ГЁ}{{\`{e}}}1 {Г¬}{{\`{i}}}1 {ГІ}{{\`{o}}}1 {Г№}{{\`{u}}}1
	{Г§}{{\c{c}}}1 {ГҮ}{{\c{C}}}1 {Гұ}{{\~n}}1 {Г‘}{{\~N}}1,
}
%% --- pxYAML: YAML configuration files ---
\lstdefinelanguage{pxYAML}{
	morekeywords     = {true,false,null,yes,no},
	morestring       = [b]',
	morestring       = [b]",
	sensitive        = false,
	comment          = [l]{\#},
	literate         =
	{:}{{\pxDEFlstoperator :}}1
	{,}{{\pxDEFlstoperator ,}}1
	{[}{{\pxDEFlsttype [ }}1
	{]}{{\pxDEFlsttype ] }}1
	{>}{{\pxDEFlstfunction > }}1
	{|}{{\pxDEFlstfunction | }}1,
}
%% --- algoritme: Catalan pseudocode with math symbol literate ---
\lstdefinelanguage{algoritme}{
	morekeywords     = {Funcio,Fi,FunciГі,Si,Llavors,SinГі,Mentre,Fer,
		Per,Cada,A,Retornar,Sortir,Nova,Nou,Afegir,Extreure},
	keywordstyle     = \pxDEFlstkeyword\bfseries,
	sensitive        = true,
	morecomment      = [l]{//},
	morecomment      = [s]{/*}{*/},
	morestring       = [b]",
	literate         =
	{<--}{{\pxDEFlstkeyword$\leftarrow$\pxDEFlstfg}}1
	{<=}{{\pxDEFlstkeyword$\leq$\pxDEFlstfg}}1
	{>=}{{\pxDEFlstkeyword$\geq$\pxDEFlstfg}}1
	{!=}{{\pxDEFlstkeyword$\neq$\pxDEFlstfg}}1
	{*}{{\pxDEFlstkeyword$\times$\pxDEFlstfg}}1
	{_}{{\pxDEFlstoperator\textunderscore\pxDEFlstfg}}1
	{ГЎ}{{\'{a}}}1 {Г©}{{\'{e}}}1 {Гӯ}{{\'{i}}}1 {Гі}{{\'{o}}}1 {Гә}{{\'{u}}}1
	{ГҒ}{{\'{A}}}1 {Гү}{{\'{E}}}1 {ГҚ}{{\'{I}}}1 {Г“}{{\'{O}}}1 {Гҡ}{{\'{U}}}1
	{Г }{{\`{a}}}1 {ГЁ}{{\`{e}}}1 {Г¬}{{\`{i}}}1 {ГІ}{{\`{o}}}1 {Г№}{{\`{u}}}1
	{ГҖ}{{\`{A}}}1 {ГҲ}{{\`{E}}}1 {ГҢ}{{\`{I}}}1 {Г’}{{\`{O}}}1 {Гҷ}{{\`{U}}}1
	{Г§}{{\c{c}}}1 {ГҮ}{{\c{C}}}1 {Гұ}{{\~n}}1 {Г‘}{{\~N}}1,
}
%% --- pxBash: Bash/shell scripts ---
\lstdefinelanguage{pxBash}{
