% =================================
% ===== BASE STYLE ===============
% =================================
\lstdefinestyle{pxlst}{
	inputencoding    = utf8,
	extendedchars    = true,
	basicstyle       = \footnotesize\linespread{1.2}\ttfamily\pxDEFlstfg,
	identifierstyle  = \pxDEFlstfg,
	commentstyle     = \itshape\pxDEFlstcomment,
	stringstyle      = \pxDEFlststring,
	keywordstyle     = \bfseries\pxDEFlstkeyword,
	keywordstyle     = [2]\bfseries\pxDEFlstfunction,
	keywordstyle     = [3]\pxDEFlsttype,
	keywordstyle     = [4]\itshape\pxDEFlsttag,
	keywordstyle     = [5]\bfseries\color{pxlst-keyword!65!},
	emphstyle        = \underbar\pxDEFlstoperator,
	showstringspaces = false,
	showspaces       = false,
	showtabs         = false,
	showlines        = false,
	breaklines       = true,
	breakatwhitespace= true,
	breakindent      = 4em,
	breakautoindent  = false,
	keepspaces       = true,
	tabsize          = 4,
	escapeinside     = {\%*}{*)},
	captionpos       = b,
	numbers          = left,
	numbersep		 = .8em,
	numberstyle      = \tiny\ttfamily\color{gray},
	prebreak  = \parbox[t][.1em][c]{\fill}{%
		\vspace{.5em}\raggedleft
		\scalebox{-.8}[1.2]{$\hookrightarrow$}
	},
	postbreak = \parbox[b][1em][c]{2em}{\scalebox{.8}{%
			$\hookrightarrow$\hspace{2em}}},
	literate =
	{á}{{\'{a}}}1 {é}{{\'{e}}}1 {í}{{\'{i}}}1 {ó}{{\'{o}}}1 {ú}{{\'{u}}}1
	{Á}{{\'{A}}}1 {É}{{\'{E}}}1 {Í}{{\'{I}}}1 {Ó}{{\'{O}}}1 {Ú}{{\'{U}}}1
	{à}{{\`{a}}}1 {è}{{\`{e}}}1 {ì}{{\`{i}}}1 {ò}{{\`{o}}}1 {ù}{{\`{u}}}1
	{À}{{\`{A}}}1 {È}{{\`{E}}}1 {Ì}{{\`{I}}}1 {Ò}{{\`{O}}}1 {Ù}{{\`{U}}}1
	{ä}{{\"a}}1  {ë}{{\"e}}1  {ï}{{\"i}}1  {ö}{{\"o}}1  {ü}{{\"u}}1
	{Ä}{{\"A}}1  {Ë}{{\"E}}1  {Ï}{{\"I}}1  {Ö}{{\"O}}1  {Ü}{{\"U}}1
	{â}{{\^a}}1  {ê}{{\^e}}1  {î}{{\^i}}1  {ô}{{\^o}}1  {û}{{\^u}}1
	{Â}{{\^A}}1  {Ê}{{\^E}}1  {Î}{{\^I}}1  {Ô}{{\^O}}1  {Û}{{\^U}}1
	{ç}{{\c{c}}}1 {Ç}{{\c{C}}}1 {ñ}{{\~n}}1 {Ñ}{{\~N}}1
	{¿}{{?`}}1   {¡}{{!`}}1,

}





