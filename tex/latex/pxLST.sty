%% ===== FILE INPUT FUNCTION ========
%% =================================
\cs_new_protected:Npn \pxLST_input_file:nn #1 #2 {
	\tcbinputlisting{
		listing~options={language=#1},
		colback=\pxDEFlstbgv!90!,
		colframe=\pxDEFlstbgv!60!,
		coltext=\pxDEFlstfgv,
		listing~file=#2,
		listing~only,
		arc=.25em, outer~arc=.25em,
		drop~lifted~shadow,
		toptitle=-.1em,
		title=\small\hspace*{\fill}\textbf{\ttfamily #2}
	}
}
%% =================================
%% ===== INLINE CODE RENDER ==========
%% =================================
%% Small tcolorbox with lstinline for single-snippet inline code.
\cs_new_protected:Npn \__pxlst_code_render_inline:n #1 {
	\tcbox[
	nobeforeafter,
	size=minimal,
	colback=\pxDEFlstbgv!90!,
	colframe=\pxDEFlstbgv!60!,
	coltext=\pxDEFlstfgv,
	boxrule=0.4pt,
	arc=0.5mm,
	left=1.5pt,
	right=1.5pt,
	top=0.5pt,
	bottom=0.5pt,
	]
	{ \lstinline{#1} }
}


%%% so that \usepackage[preset=pxcode]{pxLST} works).
%\ProcessKeysOptions{ pxLST }
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%      --  PUBLIC LaTeX2e API   --         %%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Package configuration (pxLST key family).
%%   \pxLSTsetup{key=value,...} applies keys in current TeX group scope.
%%   At document level, effects are global until overridden or group ends.
%%   Preset names are registered via \pxLSTsavepreset{name}{option-string}
%%   and applied via \pxLSTusepreset{name} or key preset=name.
\NewDocumentCommand{\pxLSTsetup}{O{dark} m O{pxlst}}{%
  \pxLSTpaletteSelect{#1}%
  \lstset{%
    language=#2,%
    style=#3%
  }%
}
%% -----------------------------------------------------------------------
%% pxCode -- inline code listing with optional local key overrides.
%%   #1 = optional key-value options (local to this environment)
%%   #2 = label string (displayed in title bar)
\newtcblisting{Code}[2][]{%
	listing~options={#1},
	listing~only,%
	arc=.25em,outer~arc=.25em,%
	drop~lifted~shadow,%
	colback=\pxDEFlstbgv!90!,
	colframe=\pxDEFlstbgv!60!,
	coltext=\pxDEFlstfgv,
	toptitle=-.1em,%
	title=\small\hspace*{\fill}\textbf{\ttfamily \color{\pxDEFlstfgvSeventyFive} #2}%
}
\newtcblisting{miniCode}[1][.8\linewidth]{%
	width=#1,
	listing~options={},
	listing~only,%
	arc=.25em,outer~arc=.25em,%
	drop~lifted~shadow,%
	colback=\pxDEFlstbgv!90!,
	colframe=\pxDEFlstbgv!60!,
	coltext=\pxDEFlstfgv,
}
%% -----------------------------------------------------------------------
%% pxCODE -- convenience environment with Darcula + pxJava defaults.
%%   Signature mirrors the legacy p3xLST environment:
%%     [#1] = language (defaults to pxJava)
%%      #2 = label shown in the title bar.
%%   Internally delegates to the pxLST key pipeline via configure.
\newtcblisting{CODE}[2][]{%
	listing~options={#1},
	listing~only,%
	arc=.25em,outer~arc=.25em,%
	colback=\pxDEFlstbgv!90!,
	colframe=\pxDEFlstbgv!60!,
	coltext=\pxDEFlstfgv,
	drop~lifted~shadow,%
	toptitle=-.1em,%
	title=\small\hspace*{\fill}\textbf{\ttfamily #2}%
}
%% -----------------------------------------------------------------------
%% pxCodeBox -- code listing with side-note comment panel (non-breakable).
%%   #1 = optional key-value options (local)
%%   #2 = label string (cross-reference anchor; inserts \label{cdbx:#2})
%%   #3 = title text (title bar)
%%   #4 = short note (comment panel identifier label)
%%   #5 = caption text (comment panel body)
\newtcblisting{CodeBox}[5][]{%
	listing~options={#1},
  enhanced,%
  colback=\pxDEFlstbgv!90!,
  colframe=\pxDEFlstbgv!60!,
  coltext=\pxDEFlstfgv,
  listing~and~comment,%
  comment=\raggedleft\parbox[b]{.1\linewidth}{%
    \textit{\footnotesize\color{gray!70!}\ttfamily codebox:\textbf{{[}#2{]}}}%
  }\hspace*{.05\linewidth}\parbox[c]{.8\linewidth}{%
    \centering #5%
  },%
  drop~lifted~shadow,%
  arc=.25em,outer~arc=.25em,%
  toptitle=-.1em,%
  title~after~break=%
    \scriptsize\texttt{\bfseries\color{gray!50!}\hspace*{-1em}..continues~from~page~\pageref{cdbx:#2}}%
    \textbf{\ttfamily\small\hspace*{\fill}#3},%
  title=%
    \scriptsize\texttt{\bfseries\color{gray!50!}\hspace*{-1em}codebox:\color{gray!80!}#4}%
    \textbf{\ttfamily\small\hspace*{\fill}#3\label{cdbx:#2}},%
  comment~outside~listing,%
  listing~above~comment%
}
%% -----------------------------------------------------------------------
%% pxCodeBreak -- same as pxCodeBox but forces breakable across pages.
%%   Arguments identical to pxCodeBox.
\newtcblisting{CodeBox*}[5][pxJava]{%
	listing~options={language=#1},
  enhanced,%
  breakable,%
  listing~and~comment,%
  comment=\raggedleft\parbox[b]{.1\linewidth}{%
    \textit{\footnotesize\color{gray!70!}\ttfamily codebox:\textbf{{[}#2{]}}}%
  }\hspace*{.05\linewidth}\parbox[c]{.8\linewidth}{%
    \centering #5%
  },%
  drop~lifted~shadow,%
  colback=\pxDEFlstbgv!90!,
  colframe=\pxDEFlstbgv!60!,
  coltext=\pxDEFlstfgv,
  arc=.25em,outer~arc=.25em,%
  toptitle=-.1em,%
  title~after~break=%
    \scriptsize\texttt{\bfseries\color{gray!50!}\hspace*{-1em}..continues~from~page~\pageref{cdbx:#2}}%
    \textbf{\ttfamily\small\hspace*{\fill}#3},%
  title=%
    \scriptsize\texttt{\bfseries\color{gray!50!}\hspace*{-1em}codebox:\color{gray!80!}#4}%
    \textbf{\ttfamily\small\hspace*{\fill}#3\label{cdbx:#2}},%
  comment~outside~listing,%
  listing~above~comment%
}
\NewDocumentCommand{\pxLSTinput}{ O{} m }
  { \pxLST_input_file:nn { #1 } { #2 } }
\NewDocumentCommand{\pxCodeInline}{ O{} m }
  {
    \group_begin:
      \tl_if_blank:nF { #1 }
        { \lstset{ language=#1, style=pxlst } }
      \__pxlst_code_render_inline:n { #2 }
    \group_end:
  }