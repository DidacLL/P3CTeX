	{Г }{{\`{a}}}1 {ГЁ}{{\`{e}}}1 {Г¬}{{\`{i}}}1 {ГІ}{{\`{o}}}1 {Г№}{{\`{u}}}1
	{ГҖ}{{\`{A}}}1 {ГҲ}{{\`{E}}}1 {ГҢ}{{\`{I}}}1 {Г’}{{\`{O}}}1 {Гҷ}{{\`{U}}}1
	{Г§}{{\c{c}}}1 {ГҮ}{{\c{C}}}1 {Гұ}{{\~n}}1 {Г‘}{{\~N}}1,
