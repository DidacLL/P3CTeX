\RequirePackage{expl3}
\RequirePackage{xparse,l3keys2e}
\RequirePackage{array}
\RequirePackage[table]{xcolor}
\RequirePackage{colortbl}
\RequirePackage{float}
\RequirePackage{longtable}
\ProvidesExplPackage{pxTAB}{2026/02/26}{v0.1}
{P3CTeX predefined tables from comma-separated rows and columns}
\file_input:n {pxTAB.code.tex}
%%% P3CTeX branded presets (registered before option processing
%%% so that \usepackage[preset=p3c-header]{pxTAB} works).
\@ifclassloaded{P3CTeX}
{
	\pxTAB_save_preset:nn { p3c-header }
	{
		style=header, headerbgcolor=primaryColor,
		headertextcolor=lighterColor,
		headerfont=\sffamily\bfseries,
		rulecolor=darkColor, arraystretch=1.3, centering=true
	}
	\pxTAB_save_preset:nn { p3c-data }
	{
		style=header-striped, headerbgcolor=primaryColor,
		headertextcolor=lighterColor,
		altrowbgcolor=secondaryColor!15,
		headerfont=\sffamily\bfseries,
		rulecolor=neutralColor, arraystretch=1.25, centering=true
	}
	\pxTAB_save_preset:nn { p3c-rubric }
	{
		style=header-grid, headerbgcolor=darkColor,
		headertextcolor=lighterColor,
		headerfont=\sffamily\bfseries,
		cellmode=paragraph, rulecolor=darkColor!50,
		arraystretch=1.4, centering=true
	}
	\pxTAB_save_preset:nn { p3c-minimal }
	{
		style=plain, rulecolor=neutralColor,
		arraystretch=1.15, tabcolsep=4pt
	}
	\pxTAB_save_preset:nn { p3c-exam }
	{
		style=header-striped, headerbgcolor=darkColor,
		headertextcolor=lighterColor,
		altrowbgcolor=lightColor!30,
		headerfont=\bfseries,
		rulecolor=darkColor!50, arraystretch=1.35, centering=true
	}
}{}
\ProcessKeysOptions{ pxTAB }
