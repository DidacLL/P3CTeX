%%%%%%%%%%%%%%  LaTeX2e API %%
%%BEGIN_FOLD%%%%%%%%%%%%%%%%%%
%% SAFE INCLUDE IMAGES OR PLACEHOLDER
%% [#1] IMAGE WIDTH *optional
%% {#2} IMAGE NAME (OR PATH)
%% [#3] PLACEHOLDER COLOR *optional
%% {#4} CAPTION TEXT
%% [#5] Image printname *optional (if not present uses #2)
\NewDocumentCommand{\pxIMG}{ O{.8\linewidth} m O{gray} m o }{\_pxIMG:nnnnn{#1}{#2}{#3}{#4}{#5}}

%% SAFE INCLUDE PAIRS OF IMAGES
%% [#1] IMAGE WIDTH *optional
%% {#2} left IMAGE NAME (OR PATH)
%% {#3} right IMAGE NAME (OR PATH)
%% [#4] PLACEHOLDER COLOR *optional
%% {#5} CAPTION TEXT
%% [#6] Image printname *optional (if not present uses #2)
\NewDocumentCommand{\pxIMGpair}{ O{.4\linewidth} m m O{gray} m o }{\__px_safeimg_pair:nnnnnn{#1}{#2}{#3}{#4}{#5}{#6}}
%% IMPORT IMAGELISTS WITH CONSECUTIVE FILENAME (randomName1.png,...,randomName5.png):
%	\addIMGList[relative/path/]{randomName}{
%%		First img caption,
%%		Second img caption,
%%		Third img caption,
%%		Fourth img caption,
%%		Fifth img caption
%%	}
\NewDocumentCommand{\pxIMGList}{O{img/} m O{} +m}{
	\foreach \captionItem[count=\i] in {#4}{
		\pxIMG{#1#2\i}{\IfBlankF{#3}{#3}\captionItem}[img:#2\i]
	}
}
