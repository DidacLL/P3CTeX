% pxSRC.sty
\RequirePackage{expl3}
\RequirePackage{color,l3keys2e,xparse}
\ProvidesExplPackage{pxSRC}{2026/02/26}{v0.2}
  {P3CTeX included sources manager (safe figure inclusion)}
% Positioning figures
\RequirePackage{float}
% Graphics inclusion
%\RequirePackage{graphicx}
% Colored boxes
\RequirePackage{tcolorbox}
% Hyperlinks configuration
%\RequirePackage{hyperref}
% Foreach loops used by \pxIMGList
%\RequirePackage{pgffor}
% Load Code
\file_input:n {pxSRC.code.tex}
%%%%%%%%%%%%%%  LaTeX2e API %%
%%BEGIN_FOLD%%%%%%%%%%%%%%%%%%
%% Package configuration (pxSRC key family).
\NewDocumentCommand{\pxSRCsetup}{m}{\keys_set:nn { pxSRC } { #1 }}

%% SAFE INCLUDE IMAGES OR PLACEHOLDER
%% [#1] IMAGE WIDTH *optional
%% {#2} IMAGE NAME (OR PATH)
%% [#3] PLACEHOLDER COLOR *optional
%% {#4} CAPTION TEXT
%% [#5] Caption short / label *optional (if not present, a safe label is auto-generated)
\NewDocumentCommand{\pxIMG}{ o m o m o }
  {
    \group_begin:
      \IfNoValueTF {#1}
        { \dim_set:Nn \l_tmpa_dim { \l__pxsrc_default_width_tl } }
        { \dim_set:Nn \l_tmpa_dim { #1 } }
      \IfNoValueTF {#3}
        { \tl_set:Nx \l__pxsrc_tmpa_tl { \l__pxsrc_placeholder_color_tl } }
        { \tl_set:Nn \l__pxsrc_tmpa_tl { #3 } }
      \IfNoValueTF {#5}
        {
          \__pxsrc_label_from_string:nN { #2 } \l__pxsrc_label_tl
          \__pxsrc_safeimg:nnnnn
            { \dim_use:N \l_tmpa_dim }{ #2 }{ \l__pxsrc_tmpa_tl }{ #4 }{ \l__pxsrc_label_tl }
        }
        {
          \__pxsrc_safeimg_short:nnnnnn
            { \dim_use:N \l_tmpa_dim }{ #2 }{ \l__pxsrc_tmpa_tl }{ #4 }{ #5 }{ #5 }
        }
    \group_end:
  }

%% SAFE INCLUDE PAIRS OF IMAGES
%% [#1] IMAGE WIDTH *optional
%% {#2} left IMAGE NAME (OR PATH)
%% {#3} right IMAGE NAME (OR PATH)
%% [#4] PLACEHOLDER COLOR *optional
%% {#5} CAPTION TEXT
%% [#6] Caption short / label *optional (if not present, a safe label is auto-generated)
\NewDocumentCommand{\pxIMGpair}{ o m m o m o }
  {
    \group_begin:
      \IfNoValueTF {#1}
        { \dim_set:Nn \l_tmpa_dim { \l__pxsrc_pair_width_tl } }
        { \dim_set:Nn \l_tmpa_dim { #1 } }
      \IfNoValueTF {#4}
        { \tl_set:Nx \l__pxsrc_tmpa_tl { \l__pxsrc_placeholder_color_tl } }
        { \tl_set:Nn \l__pxsrc_tmpa_tl { #4 } }
      \IfNoValueTF {#6}
        {
          \__pxsrc_label_from_string:nN { #2-#3 } \l__pxsrc_label_tl
          \__pxsrc_safeimg_pair:nnnnnn
            { \dim_use:N \l_tmpa_dim }{ #2 }{ #3 }{ \l__pxsrc_tmpa_tl }{ #5 }{ \l__pxsrc_label_tl }
        }
        {
          \__pxsrc_safeimg_pair_short:nnnnnnn
            { \dim_use:N \l_tmpa_dim }{ #2 }{ #3 }{ \l__pxsrc_tmpa_tl }{ #5 }{ #6 }{ #6 }
        }
    \group_end:
  }
%% IMPORT IMAGELISTS WITH CONSECUTIVE FILENAME (randomName1.png,...,randomName5.png):
%	\addIMGList[relative/path/]{randomName}{
%%		First img caption,
%%		Second img caption,
%%		Third img caption,
%%		Fourth img caption,
%%		Fifth img caption
%%	}
\NewDocumentCommand{\pxIMGList}{O{img/} m O{} +m}{
	\foreach \captionItem[count=\i] in {#4}{
		\pxIMG{#1#2\i}{\IfBlankF{#3}{#3}\captionItem}[img:#2\i]
	}
}
